[Unit]
Description=Go Trading Bot (instance %i)
After=network.target

[Service]
Type=simple
# Run as a dedicated non-root user.
# Create before deploying: useradd --system --no-create-home go-trader
User=go-trader
Group=go-trader
# WorkingDirectory stays the code checkout — shared_scripts/, .venv/, and the
# state DB (scheduler/state.db) all resolve relative to it.
WorkingDirectory=/opt/go-trader-%i
# #1056: runtime config lives OUTSIDE the deploy tree so no rsync/git-clean/rm
# can reach it. StateDirectory creates /var/lib/go-trader/%i (0750, owned by
# User/Group) and makes it writable even under ProtectSystem=strict — the daemon
# rewrites config in place (config migration, UI tuner, Discord /config), so the
# config DIRECTORY (for the atomic temp+rename), not just the file, must be
# writable. Migrate with: scripts/migrate-config-out-of-tree.sh --instance %i
StateDirectory=go-trader/%i
ExecStart=/opt/go-trader-%i/go-trader --config /var/lib/go-trader/%i/config.json
Restart=always
RestartSec=10
# Probe/deploy failures exit 78 — do not restart until scripts are synced.
# Singleton-lock refusals exit 79 (#849): another live go-trader already holds
# the state-DB lock, so staying down (one DM, no restart-loop) is correct — the
# kernel flock auto-releases on exit, so a legitimate restart is unaffected.
RestartPreventExitStatus=78 79
# Drain budget: shutdown.go caps in-flight side-effecting subprocesses at 15s
# (shutdownDrainCap), then the deferred state save + notifier flush + DB
# close run. 20s gives the binary the full drain plus a 5s buffer before
# systemd's SIGKILL backstop fires (#681).
TimeoutStopSec=20
StandardOutput=journal
StandardError=journal

# Prefer loading secrets from an instance-specific env file rather than embedding
# them in the unit file or config.json:
#   echo "DISCORD_BOT_TOKEN=Bot your-token-here" > /opt/go-trader-%i/.env
#   chmod 600 /opt/go-trader-%i/.env
EnvironmentFile=-/opt/go-trader-%i/.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
# Allow writes only to the state DB and logs directories. The config dir
# (/var/lib/go-trader/%i) is granted automatically by StateDirectory above; if
# you keep config somewhere other than /var/lib, drop StateDirectory and add
# that directory here instead.
ReadWritePaths=/opt/go-trader-%i/scheduler /opt/go-trader-%i/logs

[Install]
WantedBy=multi-user.target
